#!/usr/bin/env bash
# One-time (repeatable) server-side consolidation of every per-tenant media
# bucket into the single kal-media-prod bucket — the Phase-2 prerequisite.
#
#   scripts/media/consolidate-buckets
#   PROD_MEDIA_BUCKET=kal-media-prod scripts/media/consolidate-buckets
#
# Media keys are the intrinsic media/<uuid>/... path, so objects from different
# tenant buckets merge losslessly into one bucket (no key collisions, no
# --delete). Runnable incrementally any time before the maintenance window; a
# final in-window run catches the delta. Source buckets are read from the tenant
# registry (resources/tenants.json) — note bucket != hostname for some tenants
# (e.g. caheriaguilar.and.andrewslai.com -> "wedding").
set -euo pipefail

REPO_ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/../.." &>/dev/null && pwd)"
TENANTS_FILE="${TENANTS_FILE:-$REPO_ROOT/resources/tenants.json}"
PROD_MEDIA_BUCKET="${PROD_MEDIA_BUCKET:-kal-media-prod}"
SAMPLE_SIZE="${SAMPLE_SIZE:-20}"

log()  { printf '\033[1;34m==>\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33mWARN:\033[0m %s\n' "$*" >&2; }
die()  { printf '\033[1;31mERROR:\033[0m %s\n' "$*" >&2; exit 1; }
require_cmd() { command -v "$1" >/dev/null 2>&1 || die "Required command not found on PATH: $1"; }

require_cmd aws
require_cmd jq
[ -f "$TENANTS_FILE" ] || die "Missing tenant registry $TENANTS_FILE."

# Distinct source buckets from the registry (bucket, not hostname), target excluded.
buckets="$(jq -r '.tenants[].bucket' "$TENANTS_FILE" | sort -u)"

log "Consolidating per-tenant media into s3://$PROD_MEDIA_BUCKET/media/ ..."
while IFS= read -r bucket; do
  [ -n "$bucket" ] || continue
  if [ "$bucket" = "$PROD_MEDIA_BUCKET" ]; then
    warn "Skipping source == target ($bucket)."
    continue
  fi
  log "Syncing s3://$bucket/media/ -> s3://$PROD_MEDIA_BUCKET/media/ ..."
  aws s3 sync "s3://$bucket/media/" "s3://$PROD_MEDIA_BUCKET/media/"
done <<< "$buckets"

# Verification: every object under each source bucket's media/ prefix must now
# exist in the target. Sample up to SAMPLE_SIZE keys per source and head-object
# them against the target. Fail loudly on any miss.
log "Verifying a sample of consolidated objects exist in s3://$PROD_MEDIA_BUCKET ..."
misses=0
while IFS= read -r bucket; do
  [ -n "$bucket" ] || continue
  [ "$bucket" = "$PROD_MEDIA_BUCKET" ] && continue
  # `aws s3 ls --recursive` prints "<date> <time> <size> <key>"; column 4 is the key.
  keys="$(aws s3 ls "s3://$bucket/media/" --recursive | awk '{print $4}' | head -n "$SAMPLE_SIZE" || true)"
  while IFS= read -r key; do
    [ -n "$key" ] || continue
    if ! aws s3api head-object --bucket "$PROD_MEDIA_BUCKET" --key "$key" >/dev/null 2>&1; then
      warn "MISSING in $PROD_MEDIA_BUCKET: $key (from $bucket)"
      misses=$((misses + 1))
    fi
  done <<< "$keys"
done <<< "$buckets"

[ "$misses" -eq 0 ] || die "$misses sampled object(s) missing from $PROD_MEDIA_BUCKET — consolidation incomplete."
log "Consolidation verified: all sampled objects present in s3://$PROD_MEDIA_BUCKET."
