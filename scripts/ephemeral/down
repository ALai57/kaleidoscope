#!/usr/bin/env bash
# Tear down an ephemeral Fly.io test environment.
#
#   scripts/ephemeral/down --name=<slug>
#
# Destroys the Fly app, empties the env's S3 key prefix, and deletes the Neon
# branch. Steps are best-effort so a partial environment still fully cleans up.
# The shared kal-ephemeral bucket itself is left intact.
set -euo pipefail
# shellcheck source=scripts/ephemeral/lib.sh
source "$(dirname -- "${BASH_SOURCE[0]}")/lib.sh"

SLUG="$(resolve_slug "$@")"
APP="$(fly_app_name "$SLUG")"
BRANCH="$(neon_branch_name "$SLUG")"

load_staging_env
require_cmd fly
require_cmd neonctl
require_cmd aws

log "Tearing down ephemeral environment for slug '$SLUG'"

log "Destroying Fly app '$APP'..."
fly apps destroy "$APP" --yes || warn "Fly app '$APP' not destroyed (may not exist)."

log "Emptying S3 prefix s3://$EPHEMERAL_BUCKET/$(s3_prefix "$SLUG") ..."
aws s3 rm "s3://$EPHEMERAL_BUCKET/$(s3_prefix "$SLUG")" --recursive || warn "S3 prefix not emptied (may be empty already)."

if neon_branch_exists "$BRANCH"; then
  log "Deleting Neon branch '$BRANCH'..."
  neonctl branches delete "$BRANCH" \
    --project-id "$NEON_PROJECT_ID" --api-key "$NEON_API_KEY" || warn "Neon branch '$BRANCH' not deleted."
else
  warn "Neon branch '$BRANCH' not found — nothing to delete."
fi

log "Teardown complete for slug '$SLUG'."
