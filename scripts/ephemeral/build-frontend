#!/usr/bin/env bash
# Deploy the kaleidoscope-ui frontend to an ephemeral env's S3 prefix.
#
#   scripts/ephemeral/build-frontend --name=<slug>
#   scripts/ephemeral/build-frontend            # auto-detect + pick from deployed apps
#
# The frontend now OWNS how it's built and shipped: `npm run ephemeral:deploy`
# in kaleidoscope-ui resolves the slug (--name or interactive pick from the
# deployed kal-eph-* Fly apps), runs `vite build --mode ephemeral`, and syncs the
# dist to s3://kal-ephemeral/eph-<slug>/ where the prefixed kaleidoscope.client
# adapter (KALEIDOSCOPE_CLIENT_PREFIX, set by deploy-app) serves it. This wrapper
# just supplies staging AWS creds and a clean dep install, then delegates — the
# backend no longer knows the frontend's build command or dist path.
set -euo pipefail
# shellcheck source=scripts/ephemeral/lib.sh
source "$(dirname -- "${BASH_SOURCE[0]}")/lib.sh"

load_staging_env
require_cmd npm
: "${AWS_ACCESS_KEY_ID:?set AWS_ACCESS_KEY_ID in $STAGING_ENV_FILE}"
: "${AWS_SECRET_ACCESS_KEY:?set AWS_SECRET_ACCESS_KEY in $STAGING_ENV_FILE}"
[ -d "$FRONTEND_DIR" ] || die "Frontend repo not found at $FRONTEND_DIR (override with FRONTEND_DIR=...)."

# load_staging_env exported AWS_* into the environment; the frontend's aws s3
# sync inherits them as ambient creds. --name (from up, or the CLI) is forwarded
# so the frontend targets the same slug; with no args the frontend prompts.
log "Installing frontend deps (npm ci) in $FRONTEND_DIR ..."
( cd "$FRONTEND_DIR" && npm ci )

log "Delegating to frontend 'npm run ephemeral:deploy' in $FRONTEND_DIR ..."
( cd "$FRONTEND_DIR" && npm run ephemeral:deploy -- "$@" )
