#!/usr/bin/env bash
# Build the kaleidoscope-ui frontend and sync it to the ephemeral env's S3 prefix.
#
#   scripts/ephemeral/build-frontend --name=<slug>
#
# `vite build` writes only index.html + hashed assets/* to
# resources/kaleidoscope.client/static/dist/. Syncing that to
# s3://kal-ephemeral/eph-<slug>/ lands index.html and assets/ exactly where the
# prefixed kaleidoscope.client adapter fetches them (KALEIDOSCOPE_CLIENT_PREFIX,
# set by deploy-app), so /, /index.html, and /assets/* serve this build.
# Whatever kaleidoscope-ui is currently checked out is what ships.
set -euo pipefail
# shellcheck source=scripts/ephemeral/lib.sh
source "$(dirname -- "${BASH_SOURCE[0]}")/lib.sh"

SLUG="$(resolve_slug "$@")"
PREFIX="$(s3_prefix "$SLUG")"

load_staging_env
require_cmd npm
require_cmd aws
: "${AWS_ACCESS_KEY_ID:?set AWS_ACCESS_KEY_ID in $STAGING_ENV_FILE}"
: "${AWS_SECRET_ACCESS_KEY:?set AWS_SECRET_ACCESS_KEY in $STAGING_ENV_FILE}"
[ -d "$FRONTEND_DIR" ] || die "Frontend repo not found at $FRONTEND_DIR (override with FRONTEND_DIR=...)."

log "Building frontend in $FRONTEND_DIR (npm ci && npm run build -- --mode ephemeral)..."
( cd "$FRONTEND_DIR" && npm ci && npm run build -- --mode ephemeral)

DIST="$FRONTEND_DIR/resources/kaleidoscope.client/static/dist"
[ -f "$DIST/index.html" ] || die "Expected build output at $DIST/index.html — did vite's outDir change?"

log "Syncing $DIST/ -> s3://$EPHEMERAL_BUCKET/$PREFIX ..."
aws s3 sync "$DIST/" "s3://$EPHEMERAL_BUCKET/$PREFIX" --delete

log "Frontend deployed to s3://$EPHEMERAL_BUCKET/$PREFIX"
