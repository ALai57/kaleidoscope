#!/bin/bash

# Check domain availability
availability=$(aws route53domains check-domain-availability --domain-name "$DOMAIN_NAME" --query 'Availability' --output text)

if [ "$availability" = "AVAILABLE" ] || [ "$availability" = "AVAILABLE_RESERVED" ] || [ "$availability" = "AVAILABLE_PREORDER" ]; then
    echo "Domain $DOMAIN_NAME is available!"

    # Get domain pricing
    pricing=$(aws route53domains list-prices --query "Prices[?DomainName=='$DOMAIN_NAME']" --output json)

    echo "Pricing for $DOMAIN_NAME:"
    echo "$pricing" | jq .
else
    echo "Domain $DOMAIN_NAME is not available. Status: $availability"
fi
